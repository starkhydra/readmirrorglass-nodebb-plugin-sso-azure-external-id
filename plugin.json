{
  "url": "https://github.com/readmirrorglass/nodebb-plugin-sso-azure-external-id",
  "description": "Azure Entra External ID (CIAM) SSO for NodeBB — Authorization Code + PKCE, stable oid-based user mapping",
  "library": "./library.js",
  "hooks": [
    { "hook": "static:app.load",           "method": "init" },
    { "hook": "filter:login.build",        "method": "addLoginButton" },
    { "hook": "filter:admin.header.build", "method": "addAdminNavigation" }
  ],
  "templates": "./static/templates",
  "modules": {
    "admin/plugins/sso-azure-external-id": "./static/client/modules/admin.js"
  }
}
